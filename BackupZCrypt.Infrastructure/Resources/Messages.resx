  <data name="AesDisplayName" xml:space="preserve">
    <value>AES-256 GCM</value>
  </data>
  <data name="AesDescription" xml:space="preserve">
    <value>The industry standard encryption used by governments, banks, and most secure applications worldwide. Very fast on modern computers and phones thanks to built-in hardware support. Recommended for most users.</value>
  </data>
  <data name="AesSummary" xml:space="preserve">
    <value>Recommended — fast and widely trusted (default)</value>
  </data>
  <data name="SerpentDisplayName" xml:space="preserve">
    <value>Serpent-256 GCM</value>
  </data>
  <data name="SerpentDescription" xml:space="preserve">
    <value>Designed with an extra-large security margin, making it one of the most conservative choices available. Noticeably slower than AES, but favored when maximum caution is the priority over speed.</value>
  </data>
  <data name="SerpentSummary" xml:space="preserve">
    <value>Maximum security margin (slower than AES)</value>
  </data>
  <data name="CamelliaDisplayName" xml:space="preserve">
    <value>Camellia-256 GCM</value>
  </data>
  <data name="CamelliaDescription" xml:space="preserve">
    <value>A strong alternative to AES developed in Japan, with comparable security and performance. Recognized by international standards bodies and a good choice when a non-U.S. algorithm is preferred.</value>
  </data>
  <data name="CamelliaSummary" xml:space="preserve">
    <value>Strong AES alternative (international standard)</value>
  </data>
  <data name="ChaCha20DisplayName" xml:space="preserve">
    <value>ChaCha20-Poly1305</value>
  </data>
  <data name="ChaCha20Description" xml:space="preserve">
    <value>A modern, fast encryption method that excels on older or low-power devices that lack dedicated AES hardware. Widely used in VPNs (WireGuard), web browsing (TLS), and messaging apps.</value>
  </data>
  <data name="ChaCha20Summary" xml:space="preserve">
    <value>Fast on all devices, even without AES hardware</value>
  </data>
  <data name="TwofishDisplayName" xml:space="preserve">
    <value>Twofish-256 GCM</value>
  </data>
  <data name="TwofishDescription" xml:space="preserve">
    <value>A well-respected encryption algorithm that uses a fundamentally different internal design than AES. A solid option if you want to avoid relying on a single algorithm family.</value>
  </data>
  <data name="TwofishSummary" xml:space="preserve">
    <value>Good alternative with a different design approach</value>
  </data>
  <data name="Pbkdf2DisplayName" xml:space="preserve">
    <value>PBKDF2 (HMAC-SHA256)</value>
  </data>
  <data name="Pbkdf2Description" xml:space="preserve">
    <value>A traditional and widely compatible method to convert your password into an encryption key. Supported everywhere, but offers less protection against attackers with specialized hardware (GPUs). Choose this when compatibility with older systems is important.</value>
  </data>
  <data name="Pbkdf2Summary" xml:space="preserve">
    <value>Maximum compatibility with older systems</value>
  </data>
  <data name="Pbkdf2KeyDerivationError" xml:space="preserve">
    <value>Error deriving key with PBKDF2</value>
  </data>
  <data name="Argon2idDisplayName" xml:space="preserve">
    <value>Argon2id</value>
  </data>
  <data name="Argon2idDescription" xml:space="preserve">
    <value>The most modern and secure way to convert your password into an encryption key. Specifically designed to resist attacks using specialized hardware (GPUs, custom chips) by requiring large amounts of memory. Recommended for most users.</value>
  </data>
  <data name="Argon2idSummary" xml:space="preserve">
    <value>Recommended — strongest password protection (default)</value>
  </data>
  <data name="Argon2idKeyDerivationError" xml:space="preserve">
    <value>Error deriving key with Argon2id</value>
  </data>
  <data name="ScryptDisplayName" xml:space="preserve">
    <value>Scrypt</value>
  </data>
  <data name="ScryptDescription" xml:space="preserve">
    <value>A strong method to convert your password into an encryption key that also resists hardware-based attacks by requiring significant memory. A good middle ground between PBKDF2 and Argon2id, with wider software support than Argon2id.</value>
  </data>
  <data name="ScryptSummary" xml:space="preserve">
    <value>Strong protection, broader compatibility than Argon2id</value>
  </data>
  <data name="ScryptKeyDerivationError" xml:space="preserve">
    <value>Error deriving key with scrypt</value>
  </data>
  <data name="Sha256DisplayName" xml:space="preserve">
    <value>SHA-256</value>
  </data>
  <data name="Sha256Description" xml:space="preserve">
    <value>Replaces the filename with a unique 64-character code based on the file content. Files with the same content always get the same name, which helps detect duplicates while hiding the original name.</value>
  </data>
  <data name="Sha256Summary" xml:space="preserve">
    <value>Content-based name (64 characters)</value>
  </data>
  <data name="Sha512DisplayName" xml:space="preserve">
    <value>SHA-512</value>
  </data>
  <data name="Sha512Description" xml:space="preserve">
    <value>Same as SHA-256 but generates a longer 50-character code, offering even stronger uniqueness guarantees. Use when you need maximum assurance that no two different files share a name.</value>
  </data>
  <data name="Sha512Summary" xml:space="preserve">
    <value>Content-based name (50 characters, stronger)</value>
  </data>
  <data name="GuidDisplayName" xml:space="preserve">
    <value>GUID</value>
  </data>
  <data name="GuidDescription" xml:space="preserve">
    <value>Replaces the filename with a completely random unique identifier. Each file gets a different name every time, making it impossible to guess or correlate filenames.</value>
  </data>
  <data name="GuidSummary" xml:space="preserve">
    <value>Fully random name (maximum privacy)</value>
  </data>
  <data name="NoObfuscationDisplayName" xml:space="preserve">
    <value>None</value>
  </data>
  <data name="NoObfuscationDescription" xml:space="preserve">
    <value>Keeps the original filename as-is. Use when you don't need to hide filenames and prefer to keep them readable and organized.</value>
  </data>
  <data name="NoObfuscationSummary" xml:space="preserve">
    <value>Keeps original filename (default)</value>
  </data>
  <data name="ZstdFastDisplayName" xml:space="preserve">
    <value>Zstandard (Fast)</value>
  </data>
  <data name="ZstdFastDescription" xml:space="preserve">
    <value>Zstandard compression at minimum level, prioritizing speed over file size. Ideal when you want some compression with minimal performance impact.</value>
  </data>
  <data name="ZstdFastSummary" xml:space="preserve">
    <value>Fastest compression, larger files</value>
  </data>
  <data name="ZstdDisplayName" xml:space="preserve">
    <value>Zstandard (Normal)</value>
  </data>
  <data name="ZstdDescription" xml:space="preserve">
    <value>Zstandard compression at the default level, offering a good balance between speed and compression ratio. Recommended for most use cases.</value>
  </data>
  <data name="ZstdSummary" xml:space="preserve">
    <value>Good balance of speed and compression (recommended)</value>
  </data>
  <data name="ZstdBestDisplayName" xml:space="preserve">
    <value>Zstandard (Best)</value>
  </data>
  <data name="ZstdBestDescription" xml:space="preserve">
    <value>Zstandard compression at maximum level, achieving the smallest file sizes at the cost of longer compression time. Best for large files where minimizing size matters most.</value>
  </data>
  <data name="ZstdBestSummary" xml:space="preserve">
    <value>Smallest files, slowest compression</value>
  </data>
  <data name="NoCompressionDisplayName" xml:space="preserve">
    <value>None</value>
  </data>
  <data name="NoCompressionDescription" xml:space="preserve">
    <value>No compression is applied — files are encrypted at their original size. Best when speed matters most or files are already compressed (e.g., ZIP, JPEG, MP4).</value>
  </data>
  <data name="NoCompressionSummary" xml:space="preserve">
    <value>No compression, fastest (default)</value>
  </data>
  <data name="OperationEncryption" xml:space="preserve">
    <value>encryption</value>
  </data>
  <data name="OperationDecryption" xml:space="preserve">
    <value>decryption</value>
  </data>
